# TankBook — environment configuration
# Copy this file to .env and fill in your values before starting the stack.
#
#   cp .env.example .env

# PostgreSQL credentials
# These are used by both the database container and the app's DATABASE_URL.
DB_USER=tankbook
DB_PASSWORD=changeme

# Derived automatically from the above — no need to change this unless you
# are running the database on a separate host.
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@db/tankbook
